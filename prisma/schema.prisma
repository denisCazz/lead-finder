generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Lead {
  id          Int       @id @default(autoincrement())
  companyName String    @map("company_name")
  contactName String?   @map("contact_name")
  sector      String?
  website     String?
  email       String?
  phone       String?
  city        String?
  region      String?
  address     String?
  source      String?
  rating      Float?
  status      String    @default("new") // new, analyzed, contacted, replied, rejected
  score       Int       @default(0)
  campaignId  Int?      @map("campaign_id")
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  analyses    Analysis[]
  messages    Message[]
  logs        ActivityLog[]
  whatsappChats WhatsAppChat[]
  dealStage      String    @default("new") @map("deal_stage") // new, analyzed, contacted, replied, negotiating, won, lost
  dealNotes      String?   @map("deal_notes") @db.Text
  nextFollowUp   DateTime? @map("next_follow_up")
  lastContactedAt DateTime? @map("last_contacted_at")
  followUpCount  Int       @default(0) @map("follow_up_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([website])
  @@index([sector])
  @@index([status])
  @@index([campaignId])
  @@index([dealStage])
  @@map("leads")
}

model Analysis {
  id                Int      @id @default(autoincrement())
  leadId            Int      @map("lead_id")
  lead              Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  performanceScore  Int?     @map("performance_score")
  lcp               Float?
  fid               Float?
  cls               Float?
  hasEcommerce      Boolean  @default(false) @map("has_ecommerce")
  hasBooking        Boolean  @default(false) @map("has_booking")
  isMobileFriendly  Boolean  @default(true) @map("is_mobile_friendly")
  hasModernDesign   Boolean  @default(true) @map("has_modern_design")
  hasCrm            Boolean  @default(false) @map("has_crm")
  issuesJson        String?  @map("issues_json") @db.Text
  suggestedService  String?  @map("suggested_service")
  aiDiagnosis       String?  @map("ai_diagnosis") @db.Text
  aiScore           Int?     @map("ai_score")
  aiTokensUsed      Int?     @map("ai_tokens_used")
  analyzedAt        DateTime @default(now()) @map("analyzed_at")

  @@index([leadId])
  @@map("analyses")
}

model Message {
  id               Int      @id @default(autoincrement())
  leadId           Int      @map("lead_id")
  lead             Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type             String   @default("email") // email, whatsapp, linkedin
  subject          String?
  content          String   @db.Text
  whatsappContent  String?  @map("whatsapp_content") @db.Text
  status           String   @default("draft") // draft, approved, sent, failed
  sentAt           DateTime? @map("sent_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([leadId])
  @@index([status])
  @@map("messages")
}

model Campaign {
  id        Int      @id @default(autoincrement())
  name      String
  sector    String
  region    String?
  city      String?
  status    String   @default("active") // active, paused, completed
  leads     Lead[]
  logs      ActivityLog[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("campaigns")
}

model ActivityLog {
  id         Int       @id @default(autoincrement())
  campaignId Int?      @map("campaign_id")
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId     Int?      @map("lead_id")
  lead       Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type       String    // scrape_start, scrape_progress, scrape_done, scrape_error, ai_analysis, ai_generate, ai_qualify, analyze, generate, send
  message    String    @db.Text
  progress   Int?      // 0-100 percentage
  metadata   String?   @db.Text // JSON extra data (tokens, model, duration, etc.)
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([campaignId])
  @@index([leadId])
  @@index([createdAt])
  @@map("activity_logs")
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String @db.Text

  @@map("settings")
}

model CityLog {
  id          Int      @id @default(autoincrement())
  city        String
  region      String?
  sector      String
  campaignId  Int?     @map("campaign_id")
  leadsFound  Int      @default(0) @map("leads_found")
  scrapedAt   DateTime @default(now()) @map("scraped_at")

  @@index([city, sector])
  @@index([scrapedAt])
  @@map("city_logs")
}

model WhatsAppChat {
  id        Int      @id @default(autoincrement())
  phone     String   // normalized 39xxxxxxxxxx
  name      String?  // contact name from WhatsApp profile or lead
  leadId    Int?     @map("lead_id")
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  messages  WhatsAppMessage[]
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([phone])
  @@index([leadId])
  @@map("whatsapp_chats")
}

model WhatsAppMessage {
  id        Int      @id @default(autoincrement())
  chatId    Int      @map("chat_id")
  chat      WhatsAppChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  waId      String?  @map("wa_id") // WhatsApp message ID from Meta
  direction String   // "in" or "out"
  body      String   @db.Text
  status    String   @default("sent") // sent, delivered, read, failed
  createdAt DateTime @default(now()) @map("created_at")

  @@index([chatId])
  @@index([createdAt])
  @@map("whatsapp_messages")
}
